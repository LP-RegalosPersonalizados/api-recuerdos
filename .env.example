# =============================================
# Configuración del Servidor
# =============================================
PORT=3001

# =============================================
# SheetDB — API REST de Google Sheets
# =============================================
SHEETDB_URL=https://sheetdb.io/api/v1/TU_API_KEY_AQUI
SHEETDB_AUTH_LOGIN=        # Opcional, si activaste Basic Auth en SheetDB
SHEETDB_AUTH_PASSWORD=     # Opcional

# =============================================
# JWT — Autenticación del Admin Panel
# =============================================
JWT_SECRET=genera-una-clave-segura-con-node-e-require-crypto-randomBytes-32

# =============================================
# Admin — Credenciales para Login
# =============================================
ADMIN_EMAIL=admin@tudominio.com
ADMIN_PASSWORD=cambiar-esta-contraseña

# =============================================
# CORS — Orígenes permitidos (separados por coma)
# =============================================
CORS_ORIGINS=http://localhost:4321,http://localhost:5173,https://admin-recuerdos.vercel.app,https://www.recuerdoscompartidos.sarl

# =============================================
# Entorno — development | production | staging
# =============================================
NODE_ENV=development
